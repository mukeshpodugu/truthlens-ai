# Database Configuration
# For Docker: postgresql://truthlens_admin:truthlens_password@postgres:5432/truthlens_db
# For Local: sqlite:///./truthlens.db (auto-fallback if not connected)
DATABASE_URL=postgresql://truthlens_admin:truthlens_password@localhost:5432/truthlens_db

# Redis Caching
# For Docker: redis://redis:6379/0
# For Local: redis://localhost:6379/0 (auto-fallback to in-memory if not connected)
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=supersecretjwtkeyfortruthlensai2026!
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Model Configuration
DEFAULT_TRANSFORMER_MODEL=mrm8488/bert-tiny-finetuned-fake-news

# Environment
ENVIRONMENT=development
